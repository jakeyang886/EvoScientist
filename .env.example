# EvoScientist Gateway Environment Variables
# Copy to .env and fill in required values.

# ─── Required ───────────────────────────────────────────────
# JWT signing key — at least 32 characters, keep secret!
GATEWAY_SECRET=change-this-to-a-random-32-char-key-at-least

# ─── Optional (sensible defaults) ──────────────────────────
# Network
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8065

# Database paths (default: ~/.config/evoscientist/)
# DATABASE_URL=~/.config/evoscientist/sessions.db
# GATEWAY_DB_URL=~/.config/evoscientist/gateway.db

# CORS
CORS_ORIGINS=http://localhost:3065

# Token expiry
ACCESS_TOKEN_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=30d

# File upload
MAX_UPLOAD_SIZE=26214400

# SSE
SSE_HEARTBEAT_INTERVAL=15
SSE_TIMEOUT=600

# HITL
HITL_TIMEOUT=300

# Logging
LOG_LEVEL=INFO

# Deployment
WORKERS=4

# ─── Agent API Keys (from CLI config) ──────────────────────
# OPENAI_API_KEY=sk-...
# DEFAULT_MODEL=claude-sonnet-4

# ─── Production (email) ────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
